{
  "manifest_version": 3,
  "name": "Zapixal - Private Image Converter",
  "version": "2.5.0",
  "description": "Lightning-fast, 100% private offline image converter.",
  "icons": {
    "16": "logo.png",
    "48": "logo.png",
    "128": "logo.png"
  },
  "action": {
    "default_title": "Open Zapixal",
    "default_icon": "logo.png",
    "default_popup": "popup.html"
  },
  "permissions": [
    "contextMenus",
    "activeTab",
    "scripting",
    "sidePanel"
  ],
  "side_panel": {
    "default_path": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "commands": {
    "open-zapixal-paste": {
      "suggested_key": {
        "default": "Ctrl+Shift+Z",
        "mac": "MacCtrl+Shift+Z"
      },
      "description": "Open Zapixal to paste from clipboard"
    }
  }
}